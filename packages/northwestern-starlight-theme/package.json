{
    "name": "@nu-appdev/northwestern-starlight-theme",
    "version": "1.4.0",
    "description": "A Northwestern-branded theme for Astro Starlight",
    "license": "MIT",
    "author": "Danny Foster <danny@northwestern.edu>",
    "repository": {
        "type": "git",
        "url": "https://github.com/NIT-Administrative-Systems/northwestern-starlight-theme.git",
        "directory": "packages/northwestern-starlight-theme"
    },
    "homepage": "https://starlight-theme.entapp.northwestern.edu",
    "bugs": {
        "url": "https://github.com/NIT-Administrative-Systems/northwestern-starlight-theme/issues"
    },
    "keywords": [
        "astro",
        "starlight",
        "theme",
        "northwestern",
        "documentation",
        "plugin"
    ],
    "type": "module",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "exports": {
        ".": {
            "types": "./index.ts",
            "import": "./index.ts"
        },
        "./expressive-code": {
            "import": "./expressive-code.mjs"
        },
        "./mermaid": {
            "types": "./mermaid.ts",
            "import": "./mermaid.ts"
        },
        "./components": {
            "types": "./src/components/index.ts",
            "import": "./src/components/index.ts"
        },
        "./src/styles/components/*": "./src/styles/components/*",
        "./src/components/*": "./src/components/*",
        "./src/og/*": "./src/og/*",
        "./src/scripts/*": "./src/scripts/*",
        "./src/styles/*": "./src/styles/*"
    },
    "files": [
        "CHANGELOG.md",
        "expressive-code.mjs",
        "index.ts",
        "mermaid.ts",
        "src/"
    ],
    "dependencies": {
        "@expressive-code/plugin-line-numbers": "^0.41.7",
        "astro-og-canvas": "^0.10.1",
        "khroma": "^2.1.0"
    },
    "peerDependencies": {
        "@astrojs/starlight": ">=0.32.0",
        "astro": ">=5.1.5",
        "astro-mermaid": ">=1.3.0",
        "mermaid": ">=11.0.0"
    },
    "peerDependenciesMeta": {
        "astro-mermaid": {
            "optional": true
        },
        "mermaid": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/hast": "^3.0.4"
    }
}
