{
    "name": "@nu-appdev/northwestern-starlight-theme",
    "version": "1.5.1",
    "description": "A Northwestern-branded theme for Astro Starlight",
    "license": "MIT",
    "author": "Danny Foster <danny@northwestern.edu>",
    "repository": {
        "type": "git",
        "url": "https://github.com/NIT-Administrative-Systems/northwestern-starlight-theme.git",
        "directory": "packages/northwestern-starlight-theme"
    },
    "homepage": "https://starlight-theme.entapp.northwestern.edu",
    "bugs": {
        "url": "https://github.com/NIT-Administrative-Systems/northwestern-starlight-theme/issues"
    },
    "keywords": [
        "astro",
        "starlight",
        "theme",
        "northwestern",
        "documentation",
        "plugin"
    ],
    "type": "module",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./index.ts"
        },
        "./expressive-code": {
            "types": "./dist/expressive-code.d.ts",
            "import": "./expressive-code.ts"
        },
        "./config": {
            "types": "./dist/config.d.ts",
            "import": "./config.ts"
        },
        "./mermaid": {
            "types": "./dist/mermaid.d.ts",
            "import": "./mermaid.ts"
        },
        "./legacy-html-redirects": {
            "types": "./dist/legacy-html-redirects.d.ts",
            "import": "./legacy-html-redirects.ts"
        },
        "./components": {
            "types": "./src/components/index.ts",
            "import": "./src/components/index.ts"
        },
        "./src/styles/components/*": "./src/styles/components/*",
        "./src/components/*": "./src/components/*",
        "./src/og/*": "./src/og/*",
        "./src/scripts/*": "./src/scripts/*",
        "./src/styles/*": "./src/styles/*"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json --noCheck",
        "prepublishOnly": "pnpm build"
    },
    "files": [
        "CHANGELOG.md",
        "dist/",
        "config.ts",
        "expressive-code.ts",
        "index.ts",
        "legacy-html-redirects.ts",
        "mermaid.ts",
        "src/"
    ],
    "dependencies": {
        "@expressive-code/plugin-line-numbers": "^0.41.7",
        "@resvg/resvg-wasm": "^2.6.2",
        "khroma": "^2.1.0",
        "satori": "^0.26.0",
        "zod": "^4.3.6"
    },
    "peerDependencies": {
        "@astrojs/starlight": ">=0.32.0",
        "astro": ">=5.1.5",
        "astro-mermaid": ">=1.3.0",
        "mermaid": ">=11.0.0"
    },
    "peerDependenciesMeta": {
        "astro-mermaid": {
            "optional": true
        },
        "mermaid": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/hast": "^3.0.4",
        "typescript": "^6.0.2"
    }
}
