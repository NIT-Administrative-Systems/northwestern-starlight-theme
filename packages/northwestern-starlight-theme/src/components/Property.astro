---
interface Props {
    /** Property name (displayed in monospace). */
    name: string;
    /** Type annotation (displayed in monospace, supports union syntax). */
    type?: string;
    /** URL to link the type annotation to (e.g. a type definition or external docs). */
    typeHref?: string;
    /** Default value (displayed in monospace). */
    default?: string;
    /** Mark as required. Displays a "Required" badge. */
    required?: boolean;
    /** Mark as deprecated. Strikes through the name and mutes the row. */
    deprecated?: boolean;
    /** Version this property was added in. Displays a small badge. */
    since?: string;
}

const slugCounts = (globalThis.__nuPropertySlugs ??= new Map<string, number>());

const { name, type, typeHref, default: defaultValue, required, deprecated, since } = Astro.props;
const hasInlineBadges = required || since || deprecated;
const rawSlug = name
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
const baseSlug = `prop-${rawSlug || "key"}`;
const count = (slugCounts.get(baseSlug) ?? 0) + 1;
slugCounts.set(baseSlug, count);
const slug = count === 1 ? baseSlug : `${baseSlug}-${count}`;
---

<div class:list={["nu-property", { "nu-property--required": required, "nu-property--deprecated": deprecated }]} role="listitem" id={slug}>
    <div class="nu-property__head">
        <span class="nu-property__prop-col">
            <a class="nu-property__anchor" href={`#${slug}`} aria-label={`Link to ${name}`}>#</a><code class="nu-property__name">{name}</code>
            {hasInlineBadges && (
                <span class="nu-property__badges">
                    {required && <span class="nu-property__badge nu-property__badge--required" aria-label="required">Required</span>}
                    {since && <span class="nu-property__badge nu-property__badge--since">v{since}</span>}
                    {deprecated && <span class="nu-property__badge nu-property__badge--deprecated" aria-label="deprecated">Deprecated</span>}
                </span>
            )}
        </span>
        {type && typeHref
            ? <a class="nu-property__type-link" href={typeHref}><code class="nu-property__type">{type}</code></a>
            : type && <code class="nu-property__type">{type}</code>
        }
        <span class="nu-property__default-col">
            {defaultValue && <span class="nu-property__badge nu-property__badge--default"><code>{defaultValue}</code></span>}
        </span>
    </div>
    <div class="nu-property__description">
        <slot />
    </div>
</div>
