---
import { getTerm } from "./glossary-store.ts";
import Tooltip from "./Tooltip.astro";

interface Props {
    /** Key matching a Glossary entry. */
    of: string;
    /** Preferred position. */
    side?: "top" | "bottom";
    /** Render with a dotted underline indicator. */
    underline?: boolean;
    /** Semantic color variant. */
    variant?: "note" | "tip" | "caution" | "danger";
    /** Custom background color. */
    color?: string;
}

const { of: key, side, underline, variant, color } = Astro.props;
const tip = getTerm(key);
const hasSlot = Astro.slots.has("default");

if (!tip) {
    throw new Error(`[Term] No glossary entry found for "${key}". Add it to a <Glossary> component above this <Term>.`);
}
---

<Tooltip tip={tip} side={side} underline={underline} variant={variant} color={color}>
    {hasSlot ? <slot /> : key}
</Tooltip>
