---
import { darken, isDark, lighten, toHex } from "khroma";
import "../styles/components/tooltip.css";

type TooltipVariant = "note" | "tip" | "caution" | "danger";

interface Props {
    /** Definition text shown in the tooltip. Ignored when the content slot is used. */
    tip?: string;
    /** Preferred position. */
    side?: "top" | "bottom";
    /** Render the trigger with a dotted underline indicator. */
    underline?: boolean;
    /** Semantic variant matching Aside types. Sets background, text, and border colors. */
    variant?: TooltipVariant;
    /** Custom background color. Overrides variant. Text color is auto-computed for WCAG contrast. */
    color?: string;
}

/** Maps to --nu-color-* tokens in variables.css */
const VARIANT_COLORS: Record<TooltipVariant, string> = {
    note: "#5091cd", // --nu-color-info
    tip: "#008656", // --nu-color-success
    caution: "#ffc520", // --nu-color-warning
    danger: "#ef553f", // --nu-color-danger
};

const { tip, side = "top", underline = true, variant, color } = Astro.props;
const id = `nu-tip-${Math.random().toString(36).slice(2, 9)}`;

const hasTipSlot = Astro.slots.has("tip");

const resolvedColor = color ?? (variant ? VARIANT_COLORS[variant] : undefined);

let colorStyles: string | undefined;
if (resolvedColor) {
    const bg = toHex(resolvedColor);
    const textColor = isDark(bg) ? "#fff" : "#1a1a1a";
    const borderColor = isDark(bg) ? toHex(lighten(bg, 12)) : toHex(darken(bg, 12));
    colorStyles = `--nu-tip-bg: ${bg}; --nu-tip-text: ${textColor}; --nu-tip-border: ${borderColor}; --nu-tip-arrow: ${bg};`;
}
---

<span
    class:list={["nu-tooltip", `nu-tooltip--${side}`, { "nu-tooltip--underline": underline, "nu-tooltip--custom": !!resolvedColor }]}
    data-tooltip-id={id}
    style={colorStyles}
>
    <span class="nu-tooltip__trigger" tabindex="0" aria-describedby={id}><slot /></span>
    <span class="nu-tooltip__content" role="tooltip" id={id} popover="manual">
        {hasTipSlot ? <slot name="tip" /> : tip}
        <span class="nu-tooltip__arrow"></span>
    </span>
</span>

<script>
    const initialized = new WeakSet<HTMLElement>();

    function initTooltips() {
        document.querySelectorAll<HTMLElement>(".nu-tooltip").forEach((wrapper) => {
            if (initialized.has(wrapper)) return;
            initialized.add(wrapper);

            const trigger = wrapper.querySelector<HTMLElement>(".nu-tooltip__trigger");
            const content = wrapper.querySelector<HTMLElement>(".nu-tooltip__content");
            if (!trigger || !content) return;

            let isVisible = false;
            let openY = 0;
            const hasPopover = "showPopover" in content;
            const preferredSide = wrapper.classList.contains("nu-tooltip--bottom") ? "bottom" : "top";

            function onScroll() {
                if (!isVisible) return;
                const rect = trigger!.getBoundingClientRect();
                if (rect.bottom < 0 || rect.top > window.innerHeight || Math.abs(rect.top - openY) > 50) {
                    trigger!.blur();
                    hide();
                    return;
                }
                position();
            }

            function show() {
                if (isVisible) return;
                isVisible = true;
                openY = trigger!.getBoundingClientRect().top;
                if (hasPopover) {
                    content!.showPopover();
                } else {
                    content!.style.position = "fixed";
                    content!.style.opacity = "1";
                    content!.style.visibility = "visible";
                    content!.style.pointerEvents = "auto";
                }
                position();
                window.addEventListener("scroll", onScroll, { passive: true });
            }

            function hide() {
                if (!isVisible) return;
                isVisible = false;
                if (hasPopover) {
                    content!.hidePopover();
                } else {
                    content!.style.opacity = "0";
                    content!.style.visibility = "hidden";
                    content!.style.pointerEvents = "none";
                }
                window.removeEventListener("scroll", onScroll);
            }

            function position() {
                const rect = trigger!.getBoundingClientRect();
                const preferred = preferredSide;
                const gap = 8;
                const pad = 8;
                const vw = document.documentElement.clientWidth;

                // Measure tooltip height to decide if we need to flip
                content!.style.transform = "";
                content!.style.left = "0";
                content!.style.top = "0";
                const tipHeight = content!.offsetHeight;
                const tipWidth = content!.offsetWidth;

                // Reserve space for fixed header + mobile TOC (~100px)
                const headerZone = 100;

                // Auto-flip: if preferred side would overflow, use the other
                const spaceAbove = rect.top - headerZone - gap;
                const spaceBelow = window.innerHeight - rect.bottom - gap;
                let side = preferred;
                if (preferred === "top" && spaceAbove < tipHeight + pad && spaceBelow > spaceAbove) {
                    side = "bottom";
                } else if (preferred === "bottom" && spaceBelow < tipHeight + pad && spaceAbove > spaceBelow) {
                    side = "top";
                }

                // Update wrapper class so CSS arrow borders match
                wrapper.classList.toggle("nu-tooltip--top", side === "top");
                wrapper.classList.toggle("nu-tooltip--bottom", side === "bottom");

                content!.style.top = side === "top"
                    ? `${rect.top - gap}px`
                    : `${rect.bottom + gap}px`;

                let left = rect.left + rect.width / 2 - tipWidth / 2;
                left = Math.max(pad, Math.min(left, vw - tipWidth - pad));

                content!.style.left = `${left}px`;
                content!.style.transform = side === "top" ? "translateY(-100%)" : "";

                // Shift arrow to stay centered on trigger and flip its direction
                const arrow = content!.querySelector<HTMLElement>(".nu-tooltip__arrow");
                if (arrow) {
                    const tipCenter = left + tipWidth / 2;
                    const triggerCenter = rect.left + rect.width / 2;
                    const offset = triggerCenter - tipCenter;
                    arrow.style.left = `calc(50% + ${offset}px)`;
                }
            }

            wrapper.addEventListener("mouseenter", show);
            wrapper.addEventListener("mouseleave", hide);
            trigger.addEventListener("focus", show);
            trigger.addEventListener("blur", hide);

            content.addEventListener("mouseenter", () => { isVisible = true; });
            content.addEventListener("mouseleave", hide);
        });

    }

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
            (document.activeElement as HTMLElement)?.blur();
        }
    });

    initTooltips();
    document.addEventListener("astro:after-swap", initTooltips);
</script>
